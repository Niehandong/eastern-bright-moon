# Redis 连接 (已同步替换为您的远程 Redis 实例及鉴权)
REDIS_HOST=43.134.42.173
REDIS_PORT=16379
REDIS_DB=0
REDIS_PASSWORD="zhenshuai"

# 安全配置 (JWT 密钥)
SECRET_KEY="EASTERN_BRIGHT_MOON_SUPER_SECRET_KEY_FOR_LOCAL_DEV_2026_06"
